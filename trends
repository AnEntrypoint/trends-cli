#!/usr/bin/env node
const { execSync } = require('child_process');
const fs = require('fs');
const path = require('path');

const query = process.argv[2];
if (!query) {
  console.error('Usage: trends <query>');
  console.error('Example: trends "artificial intelligence"');
  console.error('');
  console.error('Requirements:');
  console.error('  - playwriter CLI installed (npm install -g @remorses/playwriter)');
  console.error('  - Browser window open with playwriter extension active');
  process.exit(1);
}

const repoDir = __dirname;
const modulePath = path.join(repoDir, 'playwriter-trends.js');
const tmpDir = require('os').tmpdir();
const tempFile = path.join(tmpDir, `trends-${Date.now()}.js`);

if (!fs.existsSync(modulePath)) {
  console.error(`Error: playwriter-trends.js not found at ${modulePath}`);
  process.exit(1);
}

const script = `
const { fetchTrendsData } = require('${modulePath.replace(/\\/g, '\\\\')}');

(async () => {
  try {
    const result = await fetchTrendsData('${query.replace(/'/g, "\\'")}', page);
    console.log(JSON.stringify(result, null, 2));
  } catch (err) {
    console.error('TrendsError:', err.message);
    process.exit(1);
  }
})();
`;

try {
  // Write script to temp file
  fs.writeFileSync(tempFile, script, 'utf8');

  const output = execSync(`playwriter "${tempFile}"`, {
    encoding: 'utf8',
    stdio: 'pipe'
  });

  const lines = output.split('\n');
  let jsonOutput = '';
  let foundJson = false;

  for (const line of lines) {
    if (line.trim().startsWith('{')) {
      foundJson = true;
    }
    if (foundJson) {
      jsonOutput += line + '\n';
    }
  }

  if (jsonOutput.trim()) {
    const result = JSON.parse(jsonOutput);
    console.log(JSON.stringify(result, null, 2));
  } else {
    console.error('Error: No JSON output from playwriter');
    console.error('Raw output:', output);
    process.exit(1);
  }
} catch (err) {
  if (err.message.includes('TrendsError')) {
    console.error(err.message);
  } else {
    console.error('Playwriter error:', err.message);
    console.error('Make sure:');
    console.error('  1. playwriter CLI is running: playwriter');
    console.error('  2. Browser window is open with extension active');
    console.error('  3. playwriter-trends.js is in the same directory');
  }
  process.exit(1);
} finally {
  // Clean up temp file
  try {
    if (fs.existsSync(tempFile)) {
      fs.unlinkSync(tempFile);
    }
  } catch (cleanupErr) {
    // Silently ignore cleanup errors
  }
}
