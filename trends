#!/usr/bin/env node
const { execSync } = require('child_process');
const fs = require('fs');
const path = require('path');

const query = process.argv[2];
if (!query) {
  console.error('Usage: trends <query>');
  console.error('Example: trends "artificial intelligence"');
  console.error('');
  console.error('Requirements:');
  console.error('  - playwriter CLI installed (npm install -g @remorses/playwriter)');
  console.error('  - Browser window open with playwriter extension active');
  process.exit(1);
}

const repoDir = __dirname;
const modulePath = path.join(repoDir, 'playwriter-trends.js');
const tmpDir = require('os').tmpdir();
const tempFile = path.join(tmpDir, `trends-${Date.now()}.js`);

if (!fs.existsSync(modulePath)) {
  console.error(`Error: playwriter-trends.js not found at ${modulePath}`);
  process.exit(1);
}

try {
  // Step 1: Create a new playwriter session
  let sessionId;
  try {
    const sessionOutput = execSync('playwriter session new', {
      encoding: 'utf8',
      stdio: 'pipe'
    }).trim();

    // Extract session ID from output like "Session 57 created. Use with: playwriter -s 57 -e "...""
    const match = sessionOutput.match(/Session\s+(\d+)\s+created/);
    if (!match) {
      throw new Error('Could not parse session ID from output: ' + sessionOutput);
    }
    sessionId = match[1];
  } catch (err) {
    console.error('Error: Could not create playwriter session');
    console.error('Make sure:');
    console.error('  1. playwriter serve is running on your machine');
    console.error('  2. Browser window is open with playwriter extension active');
    process.exit(1);
  }

  // Step 2: Build and write the eval code to a temporary file
  const evalCode = `
const { fetchTrendsData } = require('${modulePath.replace(/\\/g, '\\\\')}');
const result = await fetchTrendsData('${query.replace(/'/g, "\\'")}', page);
console.log(JSON.stringify(result, null, 2));
`;

  fs.writeFileSync(tempFile, evalCode, 'utf8');

  // Step 3: Execute the code via playwriter using the file
  // Read the code from file to pass via -e to avoid shell parsing issues
  const fileContent = fs.readFileSync(tempFile, 'utf8');
  const output = execSync(`playwriter -s ${sessionId} -e "${fileContent.replace(/"/g, '\\"').replace(/\$/g, '\\$')}"`, {
    encoding: 'utf8',
    stdio: 'pipe',
    shell: true
  });

  // Step 4: Parse output for JSON
  // Playwriter wraps console output as "[log] <output>"
  const lines = output.split('\n');
  let jsonOutput = '';

  for (const line of lines) {
    // Look for lines with [log] prefix or direct JSON
    const trimmed = line.trim();
    if (trimmed.startsWith('[log] {')) {
      // Extract JSON from "[log] {...}"
      jsonOutput = trimmed.substring(6); // Remove "[log] "
      break;
    } else if (trimmed.startsWith('{')) {
      // Direct JSON line
      jsonOutput = trimmed;
      break;
    }
  }

  if (jsonOutput.trim()) {
    try {
      const result = JSON.parse(jsonOutput);
      console.log(JSON.stringify(result, null, 2));
    } catch (parseErr) {
      console.error('Error: Could not parse JSON output');
      console.error('Raw output:', output);
      process.exit(1);
    }
  } else {
    console.error('Error: No JSON output from playwriter');
    console.error('Raw output:', output);
    process.exit(1);
  }
} catch (err) {
  console.error('Playwriter error:', err.message);
  console.error('Make sure:');
  console.error('  1. playwriter serve is running: playwriter serve');
  console.error('  2. Browser window is open with playwriter extension active');
  console.error('  3. playwriter-trends.js is in the same directory');
  process.exit(1);
} finally {
  // Clean up temporary file
  try {
    if (fs.existsSync(tempFile)) {
      fs.unlinkSync(tempFile);
    }
  } catch (cleanupErr) {
    // Silently ignore cleanup errors
  }
}
