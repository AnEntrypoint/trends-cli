#!/usr/bin/env node
const { execSync } = require('child_process');
const fs = require('fs');
const path = require('path');

const query = process.argv[2];
if (!query) {
  console.error('Usage: trends <query>');
  console.error('Example: trends "artificial intelligence"');
  console.error('');
  console.error('Requirements:');
  console.error('  - playwriter CLI installed (npm install -g @remorses/playwriter)');
  console.error('  - Browser window open with playwriter extension active');
  process.exit(1);
}

const repoDir = __dirname;
const modulePath = path.join(repoDir, 'playwriter-trends.js');

if (!fs.existsSync(modulePath)) {
  console.error(`Error: playwriter-trends.js not found at ${modulePath}`);
  process.exit(1);
}

try {
  // Step 1: Create a new playwriter session
  let sessionId;
  try {
    const sessionOutput = execSync('playwriter session new', {
      encoding: 'utf8',
      stdio: 'pipe'
    }).trim();
    sessionId = sessionOutput.split('\n').pop().trim();
  } catch (err) {
    console.error('Error: Could not create playwriter session');
    console.error('Make sure:');
    console.error('  1. playwriter serve is running on your machine');
    console.error('  2. Browser window is open with playwriter extension active');
    process.exit(1);
  }

  // Step 2: Build the eval code that will be executed in the session
  const evalCode = `
const { fetchTrendsData } = require('${modulePath.replace(/\\/g, '\\\\')}');
const result = await fetchTrendsData('${query.replace(/'/g, "\\'")}', page);
console.log(JSON.stringify(result, null, 2));
`;

  // Step 3: Execute the code via playwriter
  const output = execSync(`playwriter -s ${sessionId} -e "${evalCode.replace(/"/g, '\\"')}"`, {
    encoding: 'utf8',
    stdio: 'pipe'
  });

  // Step 4: Parse output for JSON
  const lines = output.split('\n');
  let jsonOutput = '';
  let foundJson = false;

  for (const line of lines) {
    if (line.trim().startsWith('{')) {
      foundJson = true;
    }
    if (foundJson) {
      jsonOutput += line + '\n';
    }
  }

  if (jsonOutput.trim()) {
    try {
      const result = JSON.parse(jsonOutput);
      console.log(JSON.stringify(result, null, 2));
    } catch (parseErr) {
      console.error('Error: Could not parse JSON output');
      console.error('Raw output:', output);
      process.exit(1);
    }
  } else {
    console.error('Error: No JSON output from playwriter');
    console.error('Raw output:', output);
    process.exit(1);
  }
} catch (err) {
  console.error('Playwriter error:', err.message);
  console.error('Make sure:');
  console.error('  1. playwriter serve is running: playwriter serve');
  console.error('  2. Browser window is open with playwriter extension active');
  console.error('  3. playwriter-trends.js is in the same directory');
  process.exit(1);
}
