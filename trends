#!/usr/bin/env node
const { execSync } = require('child_process');
const fs = require('fs');
const path = require('path');

const flags = {
  geo: '',
  time: '',
  csv: false
};

const positional = [];

for (let i = 2; i < process.argv.length; i++) {
  const arg = process.argv[i];
  if (arg === '--geo' && process.argv[i + 1]) {
    flags.geo = process.argv[++i];
  } else if (arg === '--time' && process.argv[i + 1]) {
    flags.time = process.argv[++i];
  } else if (arg === '--csv') {
    flags.csv = true;
  } else if (arg === '--help' || arg === '-h') {
    process.stdout.write([
      'Usage: trends <query> [options]',
      '',
      'Options:',
      '  --geo <code>   Region code (e.g., US, GB, DE)',
      '  --time <range> Time range (e.g., "today 12-m", "2024-01-01 2024-12-31")',
      '  --csv          Output as CSV instead of JSON',
      '  -h, --help     Show this help',
      '',
      'Examples:',
      '  trends "artificial intelligence"',
      '  trends "python" --geo US',
      '  trends "golang" --time "today 12-m" --csv',
      '  trends "python,golang,rust"',
      ''
    ].join('\n'));
    process.exit(0);
  } else {
    positional.push(arg);
  }
}

const query = positional[0];
if (!query) {
  process.stderr.write('Usage: trends <query> [--geo CODE] [--time RANGE] [--csv]\n');
  process.stderr.write('Run trends --help for more info\n');
  process.exit(1);
}

if (query.length > 500) {
  process.stderr.write('Error: query too long (max 500 characters)\n');
  process.exit(1);
}

const repoDir = __dirname;
const modulePath = path.join(repoDir, 'playwriter-trends.js');
const tmpDir = require('os').tmpdir();
const tempFile = path.join(tmpDir, `trends-${Date.now()}.js`);

if (!fs.existsSync(modulePath)) {
  process.stderr.write(`Error: playwriter-trends.js not found at ${modulePath}\n`);
  process.exit(1);
}

try {
  let sessionId;
  try {
    const sessionOutput = execSync('playwriter session new', {
      encoding: 'utf8',
      stdio: 'pipe'
    }).trim();

    const match = sessionOutput.match(/Session\s+(\d+)\s+created/);
    if (!match) {
      throw new Error('Could not parse session ID from output: ' + sessionOutput);
    }
    sessionId = match[1];
  } catch (err) {
    process.stderr.write('Error: Could not create playwriter session\n');
    process.stderr.write('Make sure:\n');
    process.stderr.write('  1. playwriter serve is running\n');
    process.stderr.write('  2. Browser with playwriter extension is active\n');
    process.exit(1);
  }

  const safeQuery = query.replace(/\\/g, '\\\\').replace(/'/g, "\\'");
  const evalCode = [
    `const { fetchTrendsData } = require('${modulePath.replace(/\\/g, '\\\\')}');`,
    `const result = await fetchTrendsData('${safeQuery}', page, {`,
    `  geo: '${flags.geo}',`,
    `  time: '${flags.time}'`,
    `});`,
    `console.log(JSON.stringify(result));`
  ].join('\n');

  fs.writeFileSync(tempFile, evalCode, 'utf8');

  const fileContent = fs.readFileSync(tempFile, 'utf8');
  const escaped = fileContent.replace(/"/g, '\\"').replace(/\$/g, '\\$');
  const output = execSync(`playwriter -s ${sessionId} -e "${escaped}"`, {
    encoding: 'utf8',
    stdio: 'pipe',
    shell: true
  });

  const lines = output.split('\n');
  let jsonOutput = '';

  for (const line of lines) {
    const trimmed = line.trim();
    if (trimmed.startsWith('[log] {')) {
      jsonOutput = trimmed.substring(6);
      break;
    }
    if (trimmed.startsWith('{')) {
      jsonOutput = trimmed;
      break;
    }
  }

  if (!jsonOutput.trim()) {
    process.stderr.write('Error: No JSON output from playwriter\n');
    process.stderr.write('Raw output: ' + output + '\n');
    process.exit(1);
  }

  const result = JSON.parse(jsonOutput);

  if (flags.csv) {
    process.stdout.write('date,value\n');
    result.timeSeriesData.forEach(row => {
      const date = row.date.includes(',') ? `"${row.date}"` : row.date;
      process.stdout.write(`${date},${row.value}\n`);
    });
  } else {
    process.stdout.write(JSON.stringify(result, null, 2) + '\n');
  }
} catch (err) {
  if (err.message && err.message.includes('Unexpected token')) {
    process.stderr.write('Error: Could not parse response from Google Trends\n');
  } else {
    process.stderr.write('Playwriter error: ' + err.message + '\n');
  }
  process.stderr.write('Make sure:\n');
  process.stderr.write('  1. playwriter serve is running\n');
  process.stderr.write('  2. Browser with playwriter extension is active\n');
  process.stderr.write('  3. playwriter-trends.js is in the same directory\n');
  process.exit(1);
} finally {
  try {
    if (fs.existsSync(tempFile)) fs.unlinkSync(tempFile);
  } catch (_) {}
}
